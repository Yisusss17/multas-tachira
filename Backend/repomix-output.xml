<file path="modules/ticketDetails.modules.js">
import database from "../database.js"

// Obtener detalles de una multa
export const GetTicketDetailsByTicketId = async (ticketId) => {
    const sql = `SELECT td.*, 
                    i.violation_description, 
                    i.ut_cost,
                    (td.ut_quantity * i.ut_cost) as total_cost_ut
                 FROM ticket_details td
                 INNER JOIN infractions i ON td.infraction_id = i.infraction_id
                 WHERE td.id_ticket = $1
                 ORDER BY td.id_detail;`
    const { rows } = await database.query(sql, [ticketId])
    return rows
}

// Obtener el total de UT de una multa
export const GetTotalUtByTicket = async (ticketId) => {
    const sql = `SELECT COALESCE(SUM(td.ut_quantity), 0) as total_ut
                 FROM ticket_details td
                 WHERE td.id_ticket = $1;`
    const { rows } = await database.query(sql, [ticketId])
    return parseFloat(rows[0].total_ut)
}

// Obtener detalle por ID
export const GetTicketDetailById = async (id) => {
    const sql = `SELECT td.*, i.violation_description, i.ut_cost
                 FROM ticket_details td
                 INNER JOIN infractions i ON td.infraction_id = i.infraction_id
                 WHERE td.id_detail = $1;`
    const { rows } = await database.query(sql, [id])
    return rows[0]
}

// Agregar detalle a una multa
export const AddTicketDetail = async (detail) => {
    const client = await database.connect()
    try {
        await client.query('BEGIN')
        
        const sql = `INSERT INTO ticket_details (id_ticket, infraction_id, ut_quantity) 
                     VALUES ($1, $2, $3) RETURNING *;`
        
        const result = await client.query(sql, [
            detail.id_ticket,
            detail.infraction_id,
            detail.ut_quantity
        ])
        
        // Actualizar total_ut de la multa
        const newTotal = await GetTotalUtByTicket(detail.id_ticket)
        await client.query(`UPDATE tickets SET total_ut = $1 WHERE id_ticket = $2;`, 
                          [newTotal, detail.id_ticket])
        
        await client.query('COMMIT')
        return result.rows[0]
    } catch (error) {
        await client.query('ROLLBACK')
        throw error
    } finally {
        client.release()
    }
}

// Eliminar detalle de una multa
export const RemoveTicketDetail = async (id_detail) => {
    const client = await database.connect()
    try {
        await client.query('BEGIN')
        
        // Obtener el id_ticket antes de eliminar
        const detail = await GetTicketDetailById(id_detail)
        if (!detail) {
            throw new Error('Detalle no encontrado')
        }
        
        const sql = `DELETE FROM ticket_details WHERE id_detail = $1 RETURNING *;`
        const result = await client.query(sql, [id_detail])
        
        // Actualizar total_ut de la multa
        const newTotal = await GetTotalUtByTicket(detail.id_ticket)
        await client.query(`UPDATE tickets SET total_ut = $1 WHERE id_ticket = $2;`, 
                          [newTotal, detail.id_ticket])
        
        await client.query('COMMIT')
        return result.rows[0]
    } catch (error) {
        await client.query('ROLLBACK')
        throw error
    } finally {
        client.release()
    }
}

// Eliminar todos los detalles de una multa
export const RemoveAllTicketDetails = async (ticketId) => {
    const sql = `DELETE FROM ticket_details WHERE id_ticket = $1 RETURNING *;`
    const { rows } = await database.query(sql, [ticketId])
    return rows
}
</file>

